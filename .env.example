# ============================================
# Job Application Agent - Docker Environment
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- PostgreSQL ---
POSTGRES_DB=jobagent
POSTGRES_USER=jobagent
POSTGRES_PASSWORD=CHANGE_ME

# --- RabbitMQ ---
RABBITMQ_USER=jobagent
RABBITMQ_PASSWORD=CHANGE_ME

# --- JWT ---
JWT_SECRET=CHANGE_ME_TO_A_64_CHAR_RANDOM_STRING
JWT_EXPIRATION_MS=86400000

# --- AI Service ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AI_SERVICE_API_KEY=CHANGE_ME

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# --- Email (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@jobagent.com

# --- Storage ---
STORAGE_TYPE=local
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
