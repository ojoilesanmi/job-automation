<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
    Add suppressions only for reviewed false positives or vulnerabilities with no available update.
    Every suppression must include a clear reason in notes and an expiry/review date.

    Example:
    <suppress until="2026-10-12Z">
        <notes><![CDATA[
        CVE reviewed on 2026-07-12. No patched version is available and the vulnerable code path is not reachable.
        Reassess before expiry.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/group/artifact@.*$</packageUrl>
        <cve>CVE-YYYY-NNNN</cve>
    </suppress>
    -->
</suppressions>
